      "type": "string",
      "title": "Mesto"
    },
    "adresaPsc": {
      "type": "string",
      "title": "PS\u010c"
    },
    "adresaStat": {
      "type": "string",
      "title": "\u0160t\u00e1t",
      "default": "SR"
    },
    "dokladTyp": {
      "type": "string",
      "enum": [
        "OP",
        "PAS",
        "POVOLENIE_NA_POBYT",
        "INE"
      ],
