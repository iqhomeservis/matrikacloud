      "type": "string",
      "title": "Titul pred"
    },
    "ziadatelTitulZa": {
      "type": "string",
      "title": "Titul za"
    },
    "rodneCislo": {
      "type": "string",
      "title": "Rodn\u00e9 \u010d\u00edslo (\u0161ifrovan\u00e9)"
    },
    "datumNarodenia": {
      "type": "string",
      "format": "date",
      "title": "D\u00e1tum narodenia"
    },
    "adresaUlica": {
      "type": "string",
      "title": "Ulica"
